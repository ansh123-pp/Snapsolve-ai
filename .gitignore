# The .classpath, .project, and .settings files are Eclipse generated files
# which you should never be forced to edit (as the "Java Builder" could
# change any of them). Exporting again from Eclipse should create the
# same files. Converting to Git should be safe as long as you follow
# Eclipse's processes.
.classpath
.cproject
.project
.pydevproject
.settings/

